<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">

<title>
<%= materia.profesor %> - <%= materia.materia %> - <%= materia.curso %>
</title>

<style>

@page{
  size:A4 portrait;
  margin:4mm;
}

*{
  box-sizing:border-box;
}

body{
  font-family:Arial, sans-serif;
  margin:0;
  padding:0;
  color:#000;
  font-size:9px;
}

.encabezado{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:8px;
}

.logo{
  width:60px;
  text-align:center;
}

.logo img{
  max-width:55px;
  max-height:55px;
}

.titulo{
  flex:1;
  text-align:center;
}

.titulo h1{
  margin:0;
  font-size:18px;
}

.titulo h2{
  margin:2px 0;
  font-size:12px;
}

.titulo h3{
  margin:0;
  font-size:10px;
  font-weight:normal;
}

.datos{
  margin-bottom:6px;
  font-size:10px;
}

.datos div{
  margin:2px 0;
}

table{
  width:100%;
  border-collapse:collapse;
  page-break-inside:avoid;
}

th,
td{
  border:1px solid #000;
  padding:2px;
  text-align:center;
  vertical-align:middle;
}

thead th{
  background:#eaeaea;
}

.col-alumno{
  width:220px;
  text-align:left;
  font-size:9px;
  font-weight:bold;
}

.nota{
  width:70px;
}

.nota-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:1px;
}

.nota-celda{
  border:1px solid #aaa;
  padding:1px;
  font-size:8px;
}

.promedio-trimestral{
  width:40px;
  font-weight:bold;
  background:#f3f3f3;
}

.examen{
  width:40px;
}

.promedio-final{
  width:50px;
  font-weight:bold;
  background:#ddd;
}

.ep{
  color:#c40000;
  font-weight:bold;
}

.no-print{
  margin-bottom:10px;
}

@media print{

  .no-print{
    display:none;
  }

}

</style>

</head>

<body>

<button
class="no-print"
onclick="window.print()"
>
Imprimir
</button>

<div class="encabezado">

  <div class="logo">
    <img src="/images/escudo.png" alt="Misiones">
  </div>

  <div class="titulo">

    <h2>Provincia de Misiones</h2>

    <h1>PLANILLA DE CALIFICACIONES</h1>

    <h3>Ciclo Lectivo <%= ciclo %></h3>

  </div>

  <div class="logo">
    <img src="/images/logo.jpg" alt="Escuela">
  </div>

</div>

<div class="datos">

  <div>
    <strong>Curso:</strong> <%= materia.curso %>
  </div>

  <div>
    <strong>Materia:</strong> <%= materia.materia %>
  </div>

  <div>
    <strong>Profesor:</strong> <%= materia.profesor %>
  </div>

</div>

<table>

<thead>

<tr>

<th rowspan="2">Alumno</th>

<% for(let tri=1; tri<=3; tri++){ %>
<th colspan="2">Trim. <%= tri %></th>
<% } %>

<th rowspan="2">Dic.</th>
<th rowspan="2">Mar.</th>
<th rowspan="2">Final</th>

</tr>

<tr>

<% for(let tri=1; tri<=3; tri++){ %>

<th>Notas</th>
<th>Prom</th>

<% } %>

</tr>

</thead>

<tbody>

<% alumnos.forEach(alumno => { %>

<tr>

<td class="col-alumno">
<%= alumno.apellido %>, <%= alumno.nombre %>
</td>

<% alumno.notas.forEach(nota => {

const arr = Object.values(nota.calificaciones)
.map(x => parseFloat(x))
.filter(x => !isNaN(x));

const prom = arr.length
? (arr.reduce((a,b)=>a+b,0)/arr.length).toFixed(1)
: '-';

%>

<td class="nota">

<div class="nota-grid">

<% [1,2,3,4].forEach(i => { %>

<div class="nota-celda">
<%= nota.calificaciones[i] ?? '-' %>
</div>

<% }) %>

</div>

</td>

<td class="promedio-trimestral">

<% if(prom !== '-' && parseFloat(prom) < 6){ %>

<span class="ep">
<%= prom %>
</span>

<% } else { %>

<%= prom %>

<% } %>

</td>

<% }) %>

<td class="examen">
<%= alumno.examen_dic ?? '-' %>
</td>

<td class="examen">
<%= alumno.examen_mar ?? '-' %>
</td>

<td class="promedio-final">

<% if(alumno.estado === 'EP'){ %>

EP

<% } else if(alumno.promedio_final !== null){ %>

<%= alumno.promedio_final.toFixed(1) %>

<% } else { %>

-

<% } %>

</td>

</tr>

<% }) %>

</tbody>

</table>

<script>

window.onload = () => {

  window.print();

  setTimeout(() => {
    window.close();
  }, 300);

};

</script>

</body>
</html>