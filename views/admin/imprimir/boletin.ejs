
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Boletín de Calificaciones</title>

<style>
    @page {
        size: A4 portrait;
        margin: 12mm;
    }

    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'Arial', 'Helvetica', sans-serif;
        font-size: 11.5px;
        color: #1a1a1a;
        line-height: 1.4;
        max-width: 720px;
        margin: 0 auto;
        background: #fff;
    }

    .no-print {
        margin-bottom: 20px;
        padding: 10px 18px;
        font-size: 14px;
    }

    /* ==================== ENCABEZADO ==================== */
    .encabezado {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        border-bottom: 3px solid #003087;
        padding-bottom: 15px;
    }

    .logo {
        width: 100px;
        text-align: center;
    }

    .logo img {
        max-width: 85px;
        max-height: 85px;
        object-fit: contain;
    }

    .titulo {
        text-align: center;
        flex: 1;
        padding: 0 15px;
    }

    .titulo h1 {
        margin: 0;
        font-size: 26px;
        font-weight: bold;
        color: #003087;
        letter-spacing: 1px;
    }

    .titulo h2 {
        margin: 6px 0 4px 0;
        font-size: 15px;
        color: #1a1a1a;
        font-weight: 600;
    }

    .titulo h3 {
        margin: 0;
        font-size: 13px;
        font-weight: normal;
        color: #444;
    }

    /* ==================== DATOS DEL ALUMNO ==================== */
    .datos {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 12px;
        background: #f8f9fa;
    }

    .datos td {
        border: 1px solid #444;
        padding: 5px 10px;
        height: 24px;
    }

    .datos td:first-child {
        width: 28%;
        font-weight: bold;
        background: #e6eef7;
        color: #003087;
    }

    /* ==================== TABLA DE NOTAS ==================== */
    .tabla-notas {
        width: 100%;
        border-collapse: collapse;
        margin: 18px 0;
    }

    .tabla-notas th {
        background: #003087;
        color: white;
        padding: 5px 4px;
        text-align: center;
        font-size: 11px;
        font-weight: 600;
    }

    .tabla-notas td {
        border: 1px solid #555;
        padding: 4px 4px;
        text-align: center;
        vertical-align: middle;
    }

    .tabla-notas td:first-child {
        text-align: left;
        font-weight: 500;
        background: #f8f9fa;
    }

    /* Resaltado de notas bajas */
    .tabla-notas td:not(:first-child) {
        font-weight: 600;
    }

    .tabla-notas,
    .tabla-inasistencias,
    .observaciones,
    .firmas {
        page-break-inside: avoid;
    }

    /* ==================== SECCIONES ==================== */
    .seccion {
        margin-top: 24px;
    }

    .seccion h3 {
        font-size: 14.5px;
        color: #003087;
        border-left: 5px solid #003087;
        padding-left: 12px;
        margin-bottom: 10px;
    }

    /* Observaciones */
    .observaciones {
        border: 2px solid #444;
        height: 80px;
        padding: 10px;
        background: #fdfdfd;
        font-style: italic;
    }

    /* Firmas */
    .firmas table {
        width: 100%;
        border: none;
        margin-top: 12px;
    }

    .firmas td {
        border: none;
        text-align: center;
        padding: 15px 10px;
        vertical-align: bottom;
    }

    .linea {
        border-top: 1.5px solid #1a1a1a;
        width: 240px;
        margin: 0 auto 8px;
    }

    .autoridad {
        margin-top: 40px;
        text-align: center;
        font-size: 12px;
    }

    .tabla-notas td:contains('EP'),
.tabla-notas td[style*="EP"] {
    color: #c62828;
    font-weight: bold;
}


.tabla-inasistencias{
    width:100%;
    border-collapse:collapse;
    margin-top:10px;
}

.tabla-inasistencias th{
    background:#003087;
    color:white;
    padding:8px;
    border:1px solid #444;
}

.tabla-inasistencias td{
    height:35px;
    border:1px solid #444;
    text-align:center;
}

    /* ==================== PRINT OPTIMIZATIONS ==================== */
    @media print {
        .no-print {
            display: none;
        }

        body {
            margin: 0;
        }

        .datos td,
        .tabla-notas td,
        .tabla-notas th {
            border: 1px solid #333;
        }
    }
</style>

</head>
<body>

<button
class="no-print"
onclick="window.print()"
>
Imprimir
</button>

<div class="encabezado">

  <div class="logo">
    <img src="/images/escudo.png" alt="Misiones">
  </div>

  <div class="titulo">

    <h2>Provincia de Misiones</h2>

    <h1>BOLETÍN DE CALIFICACIONES</h1>

    <h2>Ciclo Lectivo: 2026</h2>

  </div>

  <div class="logo">
    <img src="/images/logo.jpeg" alt="Escuela">
  </div>

</div>

<table class="datos">

<tr>
  <td width="25%">
    <strong>Apellido y Nombre</strong>
  </td>
  <td width="75%">
    <%= alumno.apellido %>, <%= alumno.nombre %>
  </td>
</tr>

<tr>
  <td>
    <strong>DNI</strong>
  </td>
  <td>
    <%= alumno.dni %>
  </td>
</tr>

<tr>
  <td>
    <strong>Edad</strong>
  </td>
  <td>
    <%= alumno.edad %> años
  </td>
</tr>



<tr>
  <td>
    <strong>Curso</strong>
  </td>
  <td>
    <%= alumno.curso %>
  </td>
</tr>

</table>

<div class="seccion">

<table class="tabla-notas">

<tr>
    <th>Materia</th>
    <th>1° Trim.</th>
    <th>2° Trim.</th>
    <th>3° Trim.</th>    
    <th>Dic.</th>
    <th>Mar.</th>
    <th>Final</th>
</tr>
</thead>

<tbody>

<% alumno.materias.forEach(m => { %>

<tr>

<td>
  <%= m.materia %>
</td>

<td>
  <%= m.t1 !== null && m.t1 < 6 ? 'EP' : (m.t1 ?? '-') %>
</td>

<td>
  <%= m.t2 !== null && m.t2 < 6 ? 'EP' : (m.t2 ?? '-') %>
</td>

<td>
  <%= m.t3 !== null && m.t3 < 6 ? 'EP' : (m.t3 ?? '-') %>
</td>




<td><%= m.nota_diciembre ?? '-' %></td>
<td><%= m.nota_marzo ?? '-' %></td>
<td>
  <%= m.estado === 'EP' ? 'EP' : m.t1 %>
</td>
</tr>

<% }) %>

</tbody>

</table>

</div>

<div class="seccion">

<div class="seccion">
    <h3>Inasistencias</h3>

    <table class="tabla-inasistencias">
        <tr>
            <th>1° Trimestre</th>
            <th>2° Trimestre</th>
            <th>3° Trimestre</th>
            <th>Total</th>
        </tr>

        <tr>
            <td><%= alumno.inasistencias_t1 || '' %></td>
            <td><%= alumno.inasistencias_t2 || '' %></td>
            <td><%= alumno.inasistencias_t3 || '' %></td>
            <td><%= alumno.inasistencias_total || '' %></td>
        </tr>
    </table>
</div>


<div class="seccion">

<h3>Observaciones</h3>

<div class="observaciones">

</div>

</div>

<div class="firmas">

<table>

<tr>

<td>

<div class="linea"></div>

Tutor
<br>
1° Trimestre

</td>

<td>

<div class="linea"></div>

Tutor
<br>
2° Trimestre

</td>

</tr>

<tr>

<td>

<div class="linea"></div>

Tutor
<br>
3° Trimestre

</td>

<td>

<div class="linea"></div>

Prof. Berent Gabriel,
<br>
Autoridad Competente

</td>

</tr>

</table>

</div>

<script>

window.onload = () => {
  window.print();
};

</script>

</body>
</html>