
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Boletín de Calificaciones</title>

<style>

@page{
  size:A4 portrait;
  margin:10mm;
}

*{
  box-sizing:border-box;
}

body{
  font-family: Arial, sans-serif;
  font-size:11px;
  color:#000;
  max-width: 700px;
  margin: auto;
}

.no-print{
  margin-bottom:15px;
}

.encabezado{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:15px;
}

.logo{
  width:90px;
  text-align:center;
}

.logo img{
  max-width:80px;
  max-height:80px;
}

.titulo{
  text-align:center;
  flex:1;
}

.titulo h1{
  margin:0;
  font-size:22px;
}

.titulo h2{
  margin:4px 0;
  font-size:14px;
}

.titulo h3{
  margin:0;
  font-size:12px;
  font-weight:normal;
}

table{
  width:100%;
  border-collapse:collapse;
}

th,
td{
  border:1px solid #000;
  padding:5px;
}

.datos td{
  height:28px;
}

.tabla-notas{
  margin-top:10px;
}

.tabla-notas th{
  text-align:center;
}

.tabla-notas td{
  text-align:center;
}

.tabla-notas td:first-child{
  text-align:left;
}

.seccion{
  margin-top:15px;
}

.seccion h3{
  margin-bottom:5px;
}

.observaciones{
  border:1px solid #000;
  height:80px;
}

.firmas{
  margin-top:25px;
}

.firmas table{
  border:none;
}

.firmas td{
  border:none;
  text-align:center;
  padding-top:30px;
}

.linea{
  border-top:1px solid #000;
  width:220px;
  margin:auto;
  margin-bottom:5px;
}

.autoridad{
  margin-top:30px;
  text-align:center;
}

@media print{

  .no-print{
    display:none;
  }

}

</style>

</head>
<body>

<button
class="no-print"
onclick="window.print()"
>
Imprimir
</button>

<div class="encabezado">

  <div class="logo">
    <img src="/images/escudo.png" alt="Misiones">
  </div>

  <div class="titulo">

    <h2>Provincia de Misiones</h2>

    <h1>BOLETÍN DE CALIFICACIONES</h1>

    <h3>Ciclo Lectivo: 2026</h3>

  </div>

  <div class="logo">
    <img src="/images/logo.jpg" alt="Escuela">
  </div>

</div>

<table class="datos">

<tr>
  <td width="25%">
    <strong>Apellido y Nombre</strong>
  </td>
  <td width="75%">
    <%= alumno.apellido %>, <%= alumno.nombre %>
  </td>
</tr>

<tr>
  <td>
    <strong>DNI</strong>
  </td>
  <td>
    <%= alumno.dni %>
  </td>
</tr>

<tr>
  <td>
    <strong>Edad</strong>
  </td>
  <td>
    <%= alumno.edad %> años
  </td>
</tr>

<tr>
  <td>
    <strong>Tutor</strong>
  </td>
  <td>
    <%= alumno.tutor || '' %>
  </td>
</tr>

<tr>
  <td>
    <strong>Curso</strong>
  </td>
  <td>
    <%= alumno.curso %>
  </td>
</tr>

</table>

<div class="seccion">

<table class="tabla-notas">

<thead>

<tr>
  <th>Materia</th>
  <th>1° Trimestre</th>
  <th>2° Trimestre</th>
  <th>3° Trimestre</th>
  <th>Promedio Final</th>
</tr>

</thead>

<tbody>

<% alumno.materias.forEach(m => { %>

<tr>

<td>
  <%= m.materia %>
</td>

<td>
  <%= m.t1 !== null && m.t1 < 6 ? 'EP' : (m.t1 ?? '-') %>
</td>

<td>
  <%= m.t2 !== null && m.t2 < 6 ? 'EP' : (m.t2 ?? '-') %>
</td>

<td>
  <%= m.t3 !== null && m.t3 < 6 ? 'EP' : (m.t3 ?? '-') %>
</td>

<td>
  <%= m.estado === 'EP' ? 'EP' : m.nota_final %>
</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

<div class="seccion">

<h3>Inasistencias</h3>

<table>

<tr>
  <td>1° Trimestre</td>
  <td></td>

  <td>2° Trimestre</td>
  <td></td>

  <td>3° Trimestre</td>
  <td></td>
</tr>

<tr>
  <td>Total</td>
  <td colspan="5"></td>
</tr>

</table>

</div>

<div class="seccion">

<h3>Exámenes Complementarios</h3>

<table>

<tr>
  <td>Examen Diciembre</td>
  <td></td>

  <td>Examen Marzo</td>
  <td></td>
</tr>

</table>

</div>

<div class="seccion">

<h3>Observaciones</h3>

<div class="observaciones">

</div>

</div>

<div class="firmas">

<table>

<tr>

<td>

<div class="linea"></div>

Tutor
<br>
1° Trimestre

</td>

<td>

<div class="linea"></div>

Tutor
<br>
2° Trimestre

</td>

</tr>

<tr>

<td>

<div class="linea"></div>

Tutor
<br>
3° Trimestre

</td>

<td>

<div class="linea"></div>

Lic. Berent Gabriel
<br>
Autoridad Competente

</td>

</tr>

</table>

</div>

<script>

window.onload = () => {
  window.print();
};

</script>

</body>
</html>